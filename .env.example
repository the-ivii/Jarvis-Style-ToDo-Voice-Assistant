# =======================================
# Voice To-Do Agent — Environment Config
# =======================================
# Copy this file to `.env` and add your key from:
#   https://aistudio.google.com/apikey

# Google AI Studio (Gemini) — required
GOOGLE_API_KEY=your_google_api_key_here

# Optional: same as GOOGLE_API_KEY (alias)
# GEMINI_API_KEY=

# Model id (see https://ai.google.dev/gemini-api/docs/models/gemini)
GEMINI_MODEL=gemini-2.0-flash

# Enable semantic memory embeddings (true/false).
USE_EMBEDDINGS=true

# Data directory for SQLite files
DATA_DIR=./data

# Server
HOST=0.0.0.0
PORT=8000
