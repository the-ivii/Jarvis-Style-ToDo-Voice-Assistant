# =======================================
# Voice To-Do Agent — Environment Config
# =======================================
# Copy this file to `.env` and fill in values.

# Which LLM provider to use: "groq" or "openai"
LLM_PROVIDER=groq

# --- Groq (free tier: https://console.groq.com/keys) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Enable semantic memory embeddings (true/false).
# When false, memory uses keyword recall only (faster cold start, no model download).
USE_EMBEDDINGS=true

# Data directory for SQLite files
DATA_DIR=./data

# Server
HOST=0.0.0.0
PORT=8000
